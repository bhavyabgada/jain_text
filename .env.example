# Anthropic (required for upload pipeline)
ANTHROPIC_API_KEY=

# Optional: override default Claude Opus model id
# ANTHROPIC_MODEL=claude-opus-4-7

# PostgreSQL (Neon, Vercel Postgres, local Docker, etc.). Use sslmode=require for managed hosts.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
